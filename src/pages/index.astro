---
import { languages } from '../i18n/ui';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/monogram.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Thorbjørn & Lorena — 5 June 2027</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Qwitcher+Grypen&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <div class="hero">
        <h1>Thorbjørn & Lorena</h1>
        <p class="tagline">Please select your language</p>
      </div>
      <nav class="lang-selector">
        {Object.entries(languages).map(([code, label]) => (
          <a href={`/${code}/`} class="lang-btn">{label}</a>
        ))}
      </nav>
    </main>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #faf9f7;
    font-family: Georgia, 'Times New Roman', serif;
    color: #2c2c2c;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    text-align: center;
    padding: 2rem;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  h1 {
    font-family: 'Qwitcher Grypen', cursive;
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 400;
    color: #2c2c2c;
    line-height: 1.1;
  }

  .tagline {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
  }

  .lang-selector {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .lang-btn {
    display: inline-block;
    padding: 0.75rem 2.5rem;
    border: 1px solid #c8c0b4;
    background: transparent;
    color: #2c2c2c;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
    min-width: 180px;
    text-align: center;
  }

  .lang-btn:hover {
    background-color: #2c2c2c;
    border-color: #2c2c2c;
    color: #faf9f7;
  }
</style>
