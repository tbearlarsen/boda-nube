---
import Base from '../../layouts/Base.astro';
---

<Base title="Venue — Thorbjørn & Lorena">
  <div class="venue">
    <h1 class="venue-name">Finca Prados Riveros</h1>

    <p class="description">
      Set within the Sierra de Guadarrama National Park, one hour north of Madrid,
      Finca Prados Riveros is a 12-hectare family estate surrounded by Scots pine
      forests and centuries-old oak groves, with sweeping views of Peñalara mountain.
      The renovated farmhouse, its glass greenhouse and private cabins sit in full nature
      while being completely equipped for an unforgettable celebration.
    </p>

    <div class="details">
      <div class="detail-row">
        <span class="detail-label">Address</span>
        <span class="detail-value">Camino del Palero, 11, 28740 Rascafría, Madrid, Spain</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Website</span>
        <a href="https://espaciospradosriveros.com" class="venue-link" target="_blank" rel="noopener noreferrer">
          espaciospradosriveros.com
        </a>
      </div>
    </div>

    <p class="getting-there-note">
      The venue is inside a national park — there is no public transport to the finca itself.
      We will arrange shuttle buses from Rascafría for all guests. More details on the
      <a href="/en/accommodation">Accommodation</a> page.
    </p>

    <iframe
      src="https://maps.google.com/maps?q=Finca+Prados+Riveros+%28Casa+El+Palero%29&output=embed"
      class="map-frame"
      loading="lazy"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
      title="Finca Prados Riveros on Google Maps"
    ></iframe>
  </div>
</Base>

<style>
  .venue {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem;
    font-family: Georgia, 'Times New Roman', serif;
    color: #2c2c2c;
  }

  .venue-name {
    font-family: 'Qwitcher Grypen', cursive;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.85;
    color: #555;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid #ddd8d0;
  }

  .detail-row {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }

  .detail-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999;
    min-width: 5rem;
    flex-shrink: 0;
  }

  .detail-value {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .venue-link {
    font-size: 0.9rem;
    color: #2c2c2c;
    text-underline-offset: 3px;
  }

  .getting-there-note {
    font-size: 0.85rem;
    color: #777;
    line-height: 1.7;
    margin-bottom: 3.5rem;
    padding-left: 1rem;
    border-left: 2px solid #ddd8d0;
  }

  .getting-there-note a {
    color: #2c2c2c;
  }

  .map-frame {
    width: 100%;
    height: 400px;
    border: 1px solid #ddd8d0;
    display: block;
  }
</style>
